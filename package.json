{
  "name": "favornoms",
  "version": "0.1.0",
  "private": true,
  "description": "Favornoms — White-label restaurant SaaS (PWA + Driver app)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@favornoms/web",
    "dev:driver": "turbo run dev --filter=@favornoms/driver",
    "dev:kds": "turbo run dev --filter=@favornoms/kds",
    "dev:pos": "turbo run dev --filter=@favornoms/pos",
    "dev:admin": "turbo run dev --filter=@favornoms/admin",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
