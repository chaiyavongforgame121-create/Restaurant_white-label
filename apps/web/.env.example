# Copy to .env.local and fill in real values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Web Push public key — same as VAPID_PUBLIC_KEY set on Edge Function secrets.
# Generate once with: node scripts/generate-vapid-keys.cjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Optional: hosts that bypass custom-domain rewriting (comma-separated).
# Defaults to localhost + 127.0.0.1 + favornoms.com + app.favornoms.com.
# NEXT_PUBLIC_APEX_HOSTS=
